generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Transaction {
  id          Int      @id @default(autoincrement())
  userId      String
  amount      Float
  description String?
  status      String   @default("PENDENTE")
  createdAt   DateTime @default(now())
}
