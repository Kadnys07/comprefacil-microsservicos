generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Transacao {
  id        Int      @id @default(autoincrement())
  usuarioId String
  valor     Float
  descricao String?
  status    String   @default("PENDENTE")
  createdAt DateTime @default(now())
}
